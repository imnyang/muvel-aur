post_install() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
  xdg-mime default Muvel.desktop x-scheme-handler/muvel
  update-desktop-database -q
}

post_upgrade() {
  post_install
}

post_remove() {
  gtk-update-icon-cache -q -t -f usr/share/icons/hicolor
  update-desktop-database -q
}
